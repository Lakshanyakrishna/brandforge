{
  "buildCommand": "cd client && npm install && npm run build && mkdir -p ../public && cp -r dist/* ../public/",
  "outputDirectory": "public",
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
