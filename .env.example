# Server
# NOTE: avoid 5000 on macOS — ControlCenter's AirPlay Receiver binds it by default.
PORT=5050
NODE_ENV=development

# Frontend origin allowed by CORS (Vite dev server default)
CLIENT_URL=http://localhost:5173

# MongoDB connection string
MONGO_URI=your_mongodb_connection_string

# Secret used to sign/verify JWT auth tokens
JWT_SECRET=your_jwt_secret_key

# ImageKit (image/PNG storage)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint

# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key
